# ===== PRODUCTION ENVIRONMENT VARIABLES =====
# Copy this to your deployment platform's environment settings

NODE_ENV=production
PORT=3000

# Database (Railway provides DATABASE_URL automatically)
# Option 1: Use DATABASE_URL (Railway/Heroku style)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Option 2: Individual variables
DB_HOST=your-db-host
DB_PORT=5432
DB_USERNAME=your-db-user
DB_PASSWORD=your-db-password
DB_NAME=debt_management_app
DB_SSL=true

# JWT - CHANGE THIS TO A RANDOM SECRET IN PRODUCTION!
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_SECRET_STRING_IN_PRODUCTION
JWT_EXPIRATION=24h

# Email (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@yourdomain.com

# Notifications
NOTIFICATION_ENABLED=true
NOTIFICATION_DAYS_THRESHOLD=30
